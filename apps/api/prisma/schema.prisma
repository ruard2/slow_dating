generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum PairRole {
  creator
  partner
}

enum GameMode {
  couple
}

enum GameRunStatus {
  lobby
  active
  completed
  abandoned
}

model Installation {
  id         String       @id @default(uuid())
  secretHash String       @unique
  accountId  String?
  createdAt  DateTime     @default(now())
  lastSeenAt DateTime     @updatedAt
  profile    Profile?
  memberships PairMember[]
  gameRuns   GameRun[]
  messages   Message[]
  waitingSessions WaitingSession[]
  waitingAnswers WaitingAnswer[]
  activityEvents ActivityEvent[]
  gameActions    GameAction[]
  invitationsSent     RouteInvitation[] @relation("InvitationsSent")
  invitationsReceived RouteInvitation[] @relation("InvitationsReceived")
  blocksMade     Block[]  @relation("BlocksMade")
  blocksReceived Block[]  @relation("BlocksReceived")
  reportsMade    Report[] @relation("ReportsMade")
  reportsAbout   Report[] @relation("ReportsAbout")
}

enum RouteInvitationStatus {
  pending
  accepted
  declined
  expired
}

model RouteInvitation {
  id                 String                @id @default(uuid())
  fromInstallationId String
  toInstallationId   String
  message            String                @default("")
  status             RouteInvitationStatus @default(pending)
  pairId             String?
  createdAt          DateTime              @default(now())
  respondedAt        DateTime?
  from Installation @relation("InvitationsSent", fields: [fromInstallationId], references: [id], onDelete: Cascade)
  to   Installation @relation("InvitationsReceived", fields: [toInstallationId], references: [id], onDelete: Cascade)

  @@index([toInstallationId, status])
  @@index([fromInstallationId, status])
}

model Block {
  id                    String       @id @default(uuid())
  byInstallationId      String
  blockedInstallationId String
  createdAt             DateTime     @default(now())
  by      Installation @relation("BlocksMade", fields: [byInstallationId], references: [id], onDelete: Cascade)
  blocked Installation @relation("BlocksReceived", fields: [blockedInstallationId], references: [id], onDelete: Cascade)

  @@unique([byInstallationId, blockedInstallationId])
  @@index([byInstallationId])
  @@index([blockedInstallationId])
}

model Report {
  id                   String       @id @default(uuid())
  byInstallationId     String
  targetInstallationId String
  reason               String
  note                 String       @default("")
  createdAt            DateTime     @default(now())
  by     Installation @relation("ReportsMade", fields: [byInstallationId], references: [id], onDelete: Cascade)
  target Installation @relation("ReportsAbout", fields: [targetInstallationId], references: [id], onDelete: Cascade)

  @@index([targetInstallationId])
}

model Account {
  id                    String          @id @default(uuid())
  email                 String          @unique
  emailVerified         Boolean         @default(false)
  passwordHash          String
  primaryInstallationId String          @unique
  createdAt             DateTime        @default(now())
  authTokens            AuthToken[]
  worldPurchases        WorldPurchase[]
}

enum AuthTokenType {
  refresh
  verify_email
  password_reset
}

model AuthToken {
  id        String        @id @default(uuid())
  accountId String
  type      AuthTokenType
  tokenHash String        @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime      @default(now())
  account   Account       @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId, type])
}

model Profile {
  id             String       @id @default(uuid())
  installationId String       @unique
  displayName    String       @default("Nieuwe bezoeker")
  bio            String       @default("")
  avatarColor    String       @default("#B9D67A")
  legacyData     Json?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  installation   Installation @relation(fields: [installationId], references: [id], onDelete: Cascade)
}

model Pair {
  id           String        @id @default(uuid())
  code         String        @unique
  createdAt    DateTime      @default(now())
  disconnectedAt DateTime?
  sharedSeconds Int           @default(0)
  bothOnlineSince DateTime?
  callUnlocked Boolean        @default(false)
  callRequestedBy String?
  callConsent Json?
  callCooldownUntil DateTime?
  developerMode Boolean       @default(false)
  members      PairMember[]
  gameRuns     GameRun[]
  progress     Progress[]
  messages     Message[]
  waitingSessions WaitingSession[]
  activityEvents ActivityEvent[]
}

model PairMember {
  id             String       @id @default(uuid())
  pairId         String
  installationId String
  role           PairRole
  joinedAt       DateTime     @default(now())
  pair           Pair         @relation(fields: [pairId], references: [id], onDelete: Cascade)
  installation   Installation @relation(fields: [installationId], references: [id], onDelete: Cascade)

  @@unique([pairId, installationId])
  @@index([installationId])
}

model WorldPurchase {
  id          String   @id @default(uuid())
  accountId   String
  world       Int
  purchasedAt DateTime @default(now())
  account     Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, world])
}

model MailOutbox {
  id        String   @id @default(uuid())
  recipient String
  type      String
  token     String
  createdAt DateTime @default(now())
}

model GameRun {
  id             String        @id @default(uuid())
  lobbyKey       String?       @unique
  gameId         String
  version        Int
  mode           GameMode
  status         GameRunStatus @default(lobby)
  revision       Int           @default(0)
  state          Json
  result         Json?
  installationId String
  pairId         String?
  startedAt      DateTime      @default(now())
  completedAt    DateTime?
  installation   Installation  @relation(fields: [installationId], references: [id], onDelete: Cascade)
  pair           Pair?         @relation(fields: [pairId], references: [id], onDelete: Cascade)
  progress       Progress[]
  waitingSessions WaitingSession[]
  activityEvents ActivityEvent[]
  actions        GameAction[]
}

model GameAction {
  id             String       @id
  gameRunId      String
  installationId String
  revision       Int
  type           String
  payload        Json
  createdAt      DateTime     @default(now())
  gameRun        GameRun      @relation(fields: [gameRunId], references: [id], onDelete: Cascade)
  installation   Installation @relation(fields: [installationId], references: [id], onDelete: Cascade)

  @@unique([gameRunId, revision])
  @@index([gameRunId, createdAt])
}

model ActivityEvent {
  id             String       @id @default(uuid())
  clientEventId  String
  installationId String
  pairId         String?
  gameRunId      String?
  gameId         String?
  category       String
  type           String
  payload        Json
  occurredAt     DateTime     @default(now())
  installation   Installation @relation(fields: [installationId], references: [id], onDelete: Cascade)
  pair           Pair?        @relation(fields: [pairId], references: [id], onDelete: SetNull)
  gameRun        GameRun?     @relation(fields: [gameRunId], references: [id], onDelete: SetNull)

  @@unique([installationId, clientEventId])
  @@index([installationId, occurredAt])
  @@index([pairId, occurredAt])
  @@index([gameRunId, occurredAt])
}

model WaitingSession {
  id        String   @id @default(uuid())
  pairId    String
  gameRunId String
  userId    String
  startedAt DateTime @default(now())
  endedAt   DateTime?
  pair      Pair     @relation(fields: [pairId], references: [id], onDelete: Cascade)
  gameRun   GameRun  @relation(fields: [gameRunId], references: [id], onDelete: Cascade)
  user      Installation @relation(fields: [userId], references: [id], onDelete: Cascade)
  answers   WaitingAnswer[]

  @@unique([gameRunId, userId])
  @@index([userId, startedAt])
}

model WaitingAnswer {
  id               String   @id @default(uuid())
  waitingSessionId String
  userId           String
  waitingGameId    String
  answerId         String
  answerLabel      String
  shareLevel       String
  createdAt        DateTime @default(now())
  waitingSession   WaitingSession @relation(fields: [waitingSessionId], references: [id], onDelete: Cascade)
  user             Installation @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model Progress {
  id             String       @id @default(uuid())
  pairId         String?
  installationId String
  gameRunId      String
  gameId         String
  payload        Json
  updatedAt      DateTime     @updatedAt
  pair           Pair?        @relation(fields: [pairId], references: [id], onDelete: Cascade)
  gameRun        GameRun      @relation(fields: [gameRunId], references: [id], onDelete: Cascade)

  @@unique([installationId, gameId])
}

model Message {
  id                   String       @id @default(uuid())
  clientId             String
  pairId               String
  senderInstallationId String
  text                 String
  sentAt               DateTime     @default(now())
  pair                 Pair         @relation(fields: [pairId], references: [id], onDelete: Cascade)
  sender               Installation @relation(fields: [senderInstallationId], references: [id], onDelete: Cascade)

  @@unique([pairId, clientId])
  @@index([pairId, sentAt])
}

model ProcessedEvent {
  id        String   @id
  createdAt DateTime @default(now())

  @@index([createdAt])
}
