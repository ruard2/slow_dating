{
  "name": "@slow-dating/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@slow-dating/config": "*",
    "@slow-dating/content": "*",
    "@slow-dating/contracts": "*",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "helmet": "^8.2.0",
    "jose": "^6.2.3",
    "pg": "^8.21.0",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^22.19.21",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "prisma": "^7.8.0",
    "supertest": "^7.2.2",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsup",
    "db:generate": "prisma generate --config prisma.config.ts",
    "db:migrate": "prisma migrate dev --config prisma.config.ts",
    "db:deploy": "prisma migrate deploy --config prisma.config.ts",
    "db:reset": "prisma migrate reset --force --config prisma.config.ts",
    "db:seed": "tsx src/dbSeed.ts",
    "test:repository": "vitest run --root ../.. apps/api/src/repository.contract.test.ts",
    "db:studio": "prisma studio --config prisma.config.ts",
    "typecheck": "tsc --noEmit",
    "start": "node dist/server.js"
  }
}
