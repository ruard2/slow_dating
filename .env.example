# Kopieer dit naar .env (staat in .gitignore) en vul je sleutel in.
# De API laadt .env automatisch bij het starten.

# AI-profielschets ----------------------------------------------------------
# Provider: "openai" (standaard) of "claude".
AI_PROFILE_PROVIDER=openai
# Zet op "false" om de AI-laag uit te schakelen (val terug op de sjabloontekst).
AI_PROFILE_ENABLED=true
# Optioneel ander model (standaard: gpt-4o voor OpenAI, claude-opus-4-8 voor Claude).
# AI_PROFILE_MODEL=gpt-4o-mini

# Eén sleutel volstaat — die van de gekozen provider.
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
